    "book": "中国迷信新研",
    "chapter": "厌镇",
    "source_file": "007.厌镇.txt",
    "line_start": 5,
    "line_end": 5,
    "quote_text": "凤阳宫殿成，帝坐殿中，若有人持兵斗殿脊者。",
