    "book": "中国迷信新研",
    "chapter": "厌胜",
    "source_file": "006.厌胜.txt",
    "line_start": 7,
    "line_end": 7,
    "quote_text": "八月，莽亲之南郊，铸作威斗。威斗者，以五石铜为之，若北斗，长二尺五寸，欲以厌胜众兵。",
    "category": "史传文句",
    "source_or_origin": "《汉书·王莽传下》",
    "summary": "王莽威斗厌胜术。",
    "notes": ""
  },
